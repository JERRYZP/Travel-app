.filter-bar {
  margin-bottom: 24rpx;
}

.search-field {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.category-scroll {
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.filter-item {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #646566;
}

.filter-item.active {
  background: #1989fa;
  color: #fff;
}

.spot-card {
  position: relative;
}

.spot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.spot-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #323233;
}

.spot-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #969799;
}

.spot-status {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
}

.status-item {
  text-align: center;
}

.status-label {
  display: block;
  font-size: 22rpx;
  color: #969799;
  margin-bottom: 8rpx;
}

.status-value {
  display: block;
  font-size: 28rpx;
  color: #323233;
  font-weight: 500;
}

.status-value.highlight {
  color: #ee0a24;
}

.spot-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.empty-state {
  padding-top: 200rpx;
}
