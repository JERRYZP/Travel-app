<view class="container">
  <van-loading wx:if="{{ loading }}" size="24px" vertical>加载中...</van-loading>

  <block wx:if="{{ !loading }}">
    <view wx:for="{{ entries }}" wx:key="spotId" class="entry-card card">
      <view class="entry-header">
        <text class="entry-name">{{ item.name }}</text>
        <van-tag type="{{ item.status === 'normal' ? 'success' : 'warning' }}">
          {{ item.statusText }}
        </van-tag>
      </view>

      <view class="entry-channels">
        <view wx:if="{{ item.officialAppid }}" class="channel-item primary" bindtap="jumpToMiniProgram" data-appid="{{ item.officialAppid }}" data-path="{{ item.officialPath }}">
          <text class="channel-name">官方小程序</text>
          <text class="channel-rate">直达率 98%</text>
          <van-button size="small" type="primary">立即打开</van-button>
        </view>

        <view wx:if="{{ item.officialWebUrl }}" class="channel-item" bindtap="copyUrl" data-url="{{ item.officialWebUrl }}">
          <text class="channel-name">官方网站</text>
          <text class="channel-rate">直达率 70%</text>
          <van-button size="small">复制网址</van-button>
        </view>
      </view>
    </view>
  </block>
</view>
